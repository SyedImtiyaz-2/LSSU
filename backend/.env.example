# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_SCHEMA=issu

# Direct DB connection — needed for running migrations via scripts/migrate.py
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── OpenAI (embeddings) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,https://lssu.edu

# Confidence threshold below which we trigger human handoff (0.0–1.0)
RAG_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K=3
